#!/bin/bash
# ghostty-notify - Launch notification viewer in Ghostty split
# Usage: ghostty-notify [project-dir]
# Requires: Ghostty terminal, notification-viewer.sh

set -e

PROJECT_DIR="${1:-$(pwd)}"
NOTIFY_SCRIPT="${HOME}/.config/opencode/plugins/examples/notification-viewer.sh"

if [[ ! -f "$NOTIFY_SCRIPT" ]]; then
    echo "Error: notification-viewer.sh not found at $NOTIFY_SCRIPT"
    echo "Please ensure tmux-notify plugin is installed."
    exit 1
fi

# Check if running in Ghostty
if [[ "$TERM_PROGRAM" != "Ghostty" ]]; then
    # Not in Ghostty - just run the viewer
    exec "$NOTIFY_SCRIPT" "$PROJECT_DIR"
fi

# Use Ghostty's split feature if available
# Ghostty supports: Ctrl+Shift+e or config binds
ghostty -e bash -c "cd '$PROJECT_DIR' && '$NOTIFY_SCRIPT' '$PROJECT_DIR'" &

disown

echo "Notification pane launched in background"
echo "Project: $PROJECT_DIR"
