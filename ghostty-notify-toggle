#!/bin/bash
# ghostty-notify-toggle - Toggle notification pane in Ghostty
# Opens notification viewer in a new split, or closes it if already open

PID_FILE="/tmp/ghostty-notify.pid"
NOTIFY_SCRIPT="${HOME}/.config/opencode/plugins/examples/notification-viewer.sh"
PROJECT_DIR="${1:-$(pwd)}"

toggle_pane() {
    if [[ -f "$PID_FILE" ]]; then
        OLD_PID=$(cat "$PID_FILE" 2>/dev/null)
        if [[ -n "$OLD_PID" ]] && kill -0 "$OLD_PID" 2>/dev/null; then
            kill "$OLD_PID" 2>/dev/null
            rm -f "$PID_FILE"
            echo "Notification pane closed"
            return 0
        fi
        rm -f "$PID_FILE"
    fi
    
    if [[ "$TERM_PROGRAM" == "Ghostty" ]]; then
        # In Ghostty - use the new split feature
        # Ghostty OSC 777 or builtin split
        osascript -e "tell application \"Ghostty\" to create split with command \"$NOTIFY_SCRIPT $PROJECT_DIR\"" 2>/dev/null || {
            echo "Could not create Ghostty split"
            return 1
        }
    else
        # Fallback - run in background
        "$NOTIFY_SCRIPT" "$PROJECT_DIR" &
        echo $! > "$PID_FILE"
    fi
    
    echo "$!" > "$PID_FILE"
    echo "Notification pane opened"
}

toggle_pane
